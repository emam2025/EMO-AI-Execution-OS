{
  "version": "1.0.0",
  "description": "Canary Metrics Schema — 14 metrics across 4 categories",
  "collection_interval_sec": 10,
  "anomaly_check_interval_sec": 30,
  "f4_observability_topic": "runtime.canary.metrics",
  "j3_readiness_topic": "runtime.readiness.canary",
  "metrics": {
    "runtime": {
      "p50_ms": {"type": "float", "unit": "ms", "description": "Median latency"},
      "p95_ms": {"type": "float", "unit": "ms", "description": "95th percentile latency"},
      "p99_ms": {"type": "float", "unit": "ms", "description": "99th percentile latency"},
      "dag_completion_rate": {"type": "float", "unit": "ratio", "description": "Fraction of DAGs completed successfully"},
      "retry_rate": {"type": "float", "unit": "ratio", "description": "Fraction of DAGs requiring retry"},
      "replay_determinism_pct": {"type": "float", "unit": "pct", "description": "Percentage of replays with identical trace hash"}
    },
    "distributed": {
      "lease_expiry_freq": {"type": "float", "unit": "freq", "description": "Lease expiry frequency per hour"},
      "ownership_conflicts": {"type": "integer", "unit": "count", "description": "Ownership conflict count"},
      "worker_recovery_time_ms": {"type": "float", "unit": "ms", "description": "Worker recovery time"},
      "scheduler_fairness_score": {"type": "float", "unit": "score", "description": "Scheduler fairness score (0-1)"}
    },
    "resource": {
      "memory_growth_per_hour": {"type": "float", "unit": "ratio", "description": "Memory growth rate per hour"},
      "cache_hit_ratio": {"type": "float", "unit": "ratio", "description": "Cache hit ratio"}
    },
    "ai": {
      "planner_determinism_drift": {"type": "float", "unit": "ratio", "description": "Planner strategy change drift"},
      "feedback_calibration_stability": {"type": "float", "unit": "ratio", "description": "Feedback calibration stability"}
    }
  },
  "anomaly_thresholds": {
    "p99_ms": 500.0,
    "replay_determinism_pct": 0.98,
    "memory_growth_per_hour": 0.05,
    "lease_conflict_count": 0,
    "scheduler_fairness_score": 0.7,
    "planner_determinism_drift": 0.02
  },
  "exit_criteria": {
    "p99_ms_max_24h_p95": 300.0,
    "replay_determinism_pct_min": 99.5,
    "memory_growth_per_hour_max": 0.01,
    "lease_conflict_count_24h": 0,
    "scheduler_fairness_score_min": 0.9,
    "scheduler_fairness_variance_max": 0.1,
    "planner_determinism_drift_max": 0.005,
    "dag_completion_rate_min": 0.999,
    "retry_rate_max": 0.02,
    "canary_duration_hours_min": 72
  }
}
