{
  "version": "1.0.0",
  "description": "Canary Rollback Criteria — EXEC-DIRECTIVE-021 stop conditions",
  "rollback_triggers": {
    "p99_latency": {
      "metric": "p99_ms",
      "threshold": 500.0,
      "condition": "> 500ms for 5 consecutive minutes",
      "action": "ROLLBACK to v4.6.0",
      "severity": "FATAL"
    },
    "replay_determinism": {
      "metric": "replay_determinism_pct",
      "threshold": 0.98,
      "condition": "< 98%",
      "action": "PAUSE + INVESTIGATE",
      "severity": "FATAL"
    },
    "memory_growth": {
      "metric": "memory_growth_per_hour",
      "threshold": 0.05,
      "condition": "> 5% sustained",
      "action": "ROLLBACK + LEAK AUDIT",
      "severity": "FATAL"
    },
    "lease_conflict": {
      "metric": "lease_conflict_count",
      "threshold": 0,
      "condition": "> 0 in 1 hour",
      "action": "PAUSE + OWNERSHIP AUDIT",
      "severity": "CRITICAL"
    },
    "scheduler_fairness": {
      "metric": "scheduler_fairness_score",
      "threshold": 0.7,
      "condition": "< 0.7 (variance > 0.3×mean)",
      "action": "PAUSE + SCHEDULER TUNING",
      "severity": "CRITICAL"
    },
    "planner_drift": {
      "metric": "planner_determinism_drift",
      "threshold": 0.02,
      "condition": "> 2% strategy change",
      "action": "PAUSE + PLANNER AUDIT",
      "severity": "WARNING"
    }
  },
  "stop_conditions": {
    "memory_leak_gt_5pct_per_hour": "IMMEDIATE STOP + ROLLBACK",
    "replay_drift_gt_2pct": "IMMEDIATE STOP + INVESTIGATE",
    "p99_gt_500ms": "IMMEDIATE STOP + ROLLBACK",
    "lease_conflict_detected": "IMMEDIATE STOP + OWNERSHIP AUDIT",
    "scheduler_unfairness_gt_0.3": "IMMEDIATE STOP + SCHEDULER TUNING"
  }
}
