# === AI-SAFE WORKSPACE STRUCTURE ===
# AI tools (OpenCode, Cursor, Copilot, Claude Code) read the filesystem directly,
# NOT through git. These ignores protect against file tree crashes and watcher overload.

# === BUILD ARTIFACTS (heaviest — 10K+ files each) ===
target/
emo-desktop/src-tauri/target/
dist/
build/
*.tar.gz
*.zip
*.dmg
*.AppImage
*.egg-info/

# === DEPENDENCIES (heavy — 100MB+ each) ===
node_modules/
emo-desktop/node_modules/
venv/
.venv/
env/

# === CACHE FILES ===
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.ai/
.ai.*
.memory/
.ruff_cache/
.mypy_cache/
.cache/
.cache/
tmp/

# === IDE/OS FILES ===
.DS_Store
**/.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# === DATABASE FILES (sensitive — user hashes) ===
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# === ENVIRONMENT / SECRETS ===
.env
.env.local
.env.production
.emo_settings.json
.emo_chat_history.json
.emo_conversations.json
*.key
*.pem
*.cert

# === LOGS / AUDIT / GENERATED ===
logs/
audit/
coverage/
*.log
*.pdf
*.html
*.pid
*.sock

# === RELEASES (archived snapshots) ===
releases/

# === RELEASE BACKUPS ===
emo-ai-BACKUP-*/

# === TEMP / SNAPSHOTS ===
.snapshot_commit_hash

# === ARTIFACTS (generated execution logs) ===
artifacts/

# === DOCKER ===
docker-compose.override.yml

# === NEXT.JS ===
next.config.js.map
