  ],
  "risks": [
    {
      "id": "R-01",
      "risk": "API key leakage (currently in JSON)",
      "probability": "high",
      "impact": "critical",
      "mitigation": "Move keys to .env + add .env to .gitignore"
    },
    {
      "id": "R-02",
      "risk": "Unreliability of external LLM models",
      "probability": "medium",
      "impact": "high",
      "mitigation": "Multiple provider support + automatic fallback"
    },
    {
      "id": "R-03",
      "risk": "Performance under heavy load",
      "probability": "medium",
      "impact": "medium",
      "mitigation": "Load testing + async processing optimization"
    },
    {
      "id": "R-04",
      "risk": "Current code complexity (large files)",
      "probability": "high",
      "impact": "medium",
      "mitigation": "Gradual restructuring after MVP"
    },
    {
      "id": "R-05",
      "risk": "Python 3.14 incompatibility with some libraries",
      "probability": "low",
      "impact": "medium",
      "mitigation": "Early compatibility testing"
    },
    {
      "id": "R-06",
      "risk": "Conversation data loss (local JSON)",
      "probability": "medium",
      "impact": "high",
      "mitigation": "Add SQLite as database"
    }
  ],
  "kpis": [
    {"name": "MVP development time", "target": "≤ 8 weeks", "measurement": "Git commit tracking"},
    {"name": "Critical test pass rate", "target": "≥ 95%", "measurement": "pytest output"},
    {"name": "Average API response time", "target": "≤ 300ms (100 concurrent)", "measurement": "Apache Bench / k6"},
    {"name": "Unit test coverage", "target": "≥ 60% (MVP), 80% (v2)", "measurement": "pytest-cov"},
    {"name": "Critical production errors", "target": "0", "measurement": "Sentry/logs"},
    {"name": "User satisfaction", "target": "≥ 4/5", "measurement": "Survey"}
  ],
  "next_steps_24h": [
