      "impact": "Determines license and level of public documentation",
      "default_assumption": "Open source — available to everyone",
      "verification_method": "Ask the decision maker",
      "status": "confirmed"
    },
    {
      "id": "M-02",
      "question": "Target number of users in MVP?",
      "impact": "Determines scalability and performance requirements",
      "default_assumption": "3 users in the first phase",
      "verification_method": "Ask the decision maker",
      "status": "confirmed"
    },
    {
      "id": "M-03",
      "question": "Monthly budget for API Keys?",
      "impact": "Determines model selection",
