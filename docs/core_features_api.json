  "risks": [
    {
      "id": "R-01",
      "risk": "تسرب مفاتيح API (موجودة حالياً في JSON)",
      "probability": "high",
      "impact": "critical",
      "mitigation": "نقل فوري لـ .env + إضافة .env لـ .gitignore"
    },
    {
      "id": "R-02",
      "risk": "عدم استقرار نماذج LLM الخارجية",
      "probability": "medium",
      "impact": "high",
      "mitigation": "دعم مزودين متعددين + fallback تلقائي"
    },
    {
      "id": "R-03",
      "risk": "الأداء تحت الحمل الثقيل",
      "probability": "medium",
      "impact": "medium",
      "mitigation": "اختبارات تحميل + تحسين async processing"
    },
    {
      "id": "R-04",
      "risk": "تعقيد الكود الحالي (ملفات كبيرة)",
      "probability": "high",
      "impact": "medium",
      "mitigation": "إعادة هيكلة تدريجية بعد MVP"
    },
    {
      "id": "R-05",
      "risk": "عدم توافق Python 3.14 مع بعض المكتبات",
      "probability": "low",
      "impact": "medium",
      "mitigation": "اختبار التوافق مبكراً"
    },
    {
      "id": "R-06",
      "risk": "فقدان بيانات المحادثات (JSON محلي)",
      "probability": "medium",
      "impact": "high",
      "mitigation": "إضافة SQLite كقاعدة بيانات"
    }
  ],
  "kpis": [
