      "action": "Secure API keys",
      "command": "mv .emo_settings.json .emo_settings.json.bak && create .env with keys",
      "estimated_time": "30 minutes",
      "priority": "critical"
    },
    {
      "step": 2,
      "action": "Connect brain.py to OpenRouter API",
