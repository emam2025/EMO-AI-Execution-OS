{
  "document": "EMO AI Orchestrator — Core Features & API Specification",
  "version": "1.2.0",
  "date": "2026-05-17",
  "author": "Emam AbdullAziz",
  "status": "ALL DECISIONS CONFIRMED — Ready for exploration phase",
  "project": {
    "name": "EMO AI Orchestrator",
    "current_version": "4.0.0",
    "framework": "FastAPI",
    "python_version": "3.14",
    "platforms": ["macOS", "Windows", "Android (web-responsive)"],
    "license": "Open Source (MIT/Apache 2.0 — TBD)",
    "access": "Public — available for everyone",
    "llm_mode": "API (OpenRouter/Groq/Gemini) or Local (Ollama)",
    "database": "SQLite (default, no user preference)",
    "api_keys": "User-provided (free tier or paid)",
    "target_users_mvp": 3,
    "compliance": ["GDPR", "SOC2"],
    "deadline": "Task-driven (not time-based)",
    "telegram_bot": "Must have in MVP"
  },
  "features": [
    {
      "id": "FR-01",
      "name_ar": "Conversation Management",
      "name_en": "Conversation Management",
      "priority": "Must",
      "status": "partial",
      "description": "Create and manage multiple conversations with history",
      "acceptance_criteria": [
        "Create a new conversation with custom name",
        "Activate and switch between conversations",
        "Delete a conversation with all its messages",
        "View conversation list with message count"
      ],
      "endpoints": [
        "POST /api/conversations",
        "GET /api/conversations",
        "POST /api/conversations/{id}/activate",
        "DELETE /api/conversations/{id}",
        "GET /api/history"
      ]
    },
    {
      "id": "FR-02",
      "name_ar": "Multi-Agent System",
      "name_en": "Multi-Agent System",
      "priority": "Must",
      "status": "stub",
      "description": "Specialized agents collaborating to execute tasks",
      "agents": [
        {"name": "planner", "role": "Plan and distribute tasks", "color": "#8b5cf6"},
        {"name": "coder", "role": "Write and debug code", "color": "#10b981"},
        {"name": "writer", "role": "Write documents and content", "color": "#ec4899"},
        {"name": "researcher", "role": "Research and verify facts", "color": "#f59e0b"}
      ],
      "acceptance_criteria": [
        "Automatically route requests to the appropriate agent",
        "Each agent connects to a real LLM model",
        "Display each agent's status (idle/busy/error)",
        "Support for custom agents"
      ]
    },
    {
      "id": "FR-03",
      "name_ar": "LLM Integration",
      "name_en": "LLM Integration",
      "priority": "Must",
      "status": "stub",
      "description": "Connect to AI models via multiple providers",
      "providers": [
        {"name": "openrouter", "type": "api", "priority": 1, "env_key": "OPENROUTER_API_KEY"},
        {"name": "groq", "type": "api", "priority": 2, "env_key": "GROQ_API_KEY"},
        {"name": "gemini", "type": "api", "priority": 3, "env_key": "GEMINI_API_KEY"},
        {"name": "ollama", "type": "local", "priority": 4, "env_key": "", "default_url": "http://localhost:11434", "note": "Local LLM via Ollama"}
      ],
      "acceptance_criteria": [
        "Connect to a real LLM model and receive a response",
        "Test connection and display provider status",
        "Switch between providers from settings",
        "Automatic fallback when primary provider fails"
      ]
    },
    {
      "id": "FR-04",
      "name_ar": "Tools System",
      "name_en": "Tools System",
      "priority": "Must",
      "status": "exists-not-connected",
      "description": "Library of tools executed automatically by agents",
      "categories": {
        "DevOps": ["vercel_deploy", "docker_build", "docker_run", "env_manager"],
        "Project Intelligence": ["auto_debugger", "ai_code_reviewer", "project_monitor", "project_scaffold", "project_analyzer", "dependency_manager", "codebase_refactor", "deployment_builder"],
        "GitHub": ["github_create_repo", "github_clone_repo", "github_push_changes", "github_pull_repo", "github_read_file", "github_write_file", "github_create_branch"],
        "Supabase": ["supabase_create_project", "supabase_create_table", "supabase_insert_data", "supabase_query", "supabase_auth_setup", "supabase_storage_upload"],
        "Firebase": ["firebase_init_project", "firebase_auth_setup", "firebase_firestore_write", "firebase_firestore_read", "firebase_deploy"],
        "System": ["shell", "files"]
      },
      "acceptance_criteria": [
        "Agents can call tools automatically",
        "Each tool returns a structured result (JSON)",
        "Protect dangerous tools with permissions system",
        "Display available tools in the interface"
      ]
    },
    {
      "id": "FR-05",
      "name_ar": "Task Management",
      "name_en": "Task Management",
      "priority": "Must",
      "status": "partial",
      "description": "Track tasks from creation to completion",
      "states": ["pending", "running", "complete", "error"],
      "acceptance_criteria": [
        "Create a task with pending status",
        "Update status on start and completion",
        "Live streaming of progress via SSE",
        "Auto-cleanup of old tasks (after 24 hours)"
      ]
    },
    {
      "id": "FR-06",
      "name_ar": "Memory & Context",
      "name_en": "Memory & Context",
      "priority": "Must",
      "status": "partial",
      "description": "Build and manage conversation context",
      "acceptance_criteria": [
        "Maximum 12 messages in context",
        "Maximum 1200 characters per message",
        "Clean noisy text",
        "Maintain role structure (user/assistant/system)"
      ]
    },
    {
      "id": "FR-07",
      "name_ar": "Web UI",
      "name_en": "Web UI",
      "priority": "Must",
      "status": "exists",
      "description": "Interactive chat interface with Glass Morphism design",
      "features": {
        "languages": ["en", "ar"],
        "themes": ["dark", "light"],
        "components": ["chat", "settings", "tools_library", "execution_log", "task_list", "agent_status", "conversations"]
      },
      "acceptance_criteria": [
        "Responsive interface working on mobile and desktop",
        "RTL for Arabic and LTR for English",
        "Smooth toggle between dark and light modes",
        "Full settings panel"
      ]
    },
    {
      "id": "FR-08",
      "name_ar": "Telegram Integration",
      "name_en": "Telegram Integration",
      "priority": "Should",
      "status": "exists",
      "description": "Telegram bot for interacting with the system",
      "commands": ["/start", "/chat", "/status", "/help"],
      "acceptance_criteria": [
        "Authorize users via /start",
        "Receive messages and send replies",
        "Split long messages (>4000 characters)"
      ]
    },
    {
      "id": "FR-09",
      "name_ar": "System Tray App",
      "name_en": "System Tray App",
      "priority": "Should",
      "status": "exists",
      "description": "macOS app for server monitoring",
      "acceptance_criteria": [
        "Monitor server status every 5 seconds",
        "Restart server with one click",
        "Notifications on status change"
      ]
    },
    {
      "id": "FR-10",
      "name_ar": "Security & Authentication",
      "name_en": "Security & Authentication",
      "priority": "Must",
      "status": "disabled",
      "description": "System protection and authentication",
      "acceptance_criteria": [
        "Username/password authentication with token",
        "Protect API keys in .env",
        "Permissions system for tools",
        "Encrypt sensitive data"
      ]
    }
  ],
  "api_specification": {
    "base_url": "http://localhost:8080",
    "auth": "Bearer token (when auth_enabled=true)",
    "endpoints": {
      "GET /": {
        "description": "Server status",
        "auth_required": false,
        "response": {
          "200": {
            "name": "Emo AI Orchestrator",
            "version": "4.0.0",
            "status": "running"
          }
        }
      },
      "POST /api/chat": {
        "description": "Send a message and start a task",
        "auth_required": false,
        "request_body": {
          "message": {"type": "string", "required": true, "max_length": 10000},
          "conversation_id": {"type": "string", "required": false, "format": "uuid"},
          "file_name": {"type": "string", "required": false},
          "file_type": {"type": "string", "required": false},
          "file_size": {"type": "integer", "required": false},
          "base64": {"type": "string", "required": false}
        },
        "response": {
          "200": {
            "task_id": "string (8-char UUID)",
            "status": "started"
          }
        }
      },
      "GET /api/stream/{task_id}": {
        "description": "Live stream of task progress (Server-Sent Events)",
        "auth_required": false,
        "content_type": "text/event-stream",
        "events": [
          {
            "event": "step_start",
            "data": {"step": "string", "agent": "string", "tool": "string"}
          },
          {
            "event": "step_complete",
            "data": {"step": "string", "result": "string"}
          },
          {
            "event": "result",
            "data": {"content": "string"}
          },
          {
            "event": "error",
            "data": {"message": "string", "code": "string"}
          }
        ]
      },
      "GET /api/tasks": {
        "description": "Task list",
        "auth_required": false,
        "query_params": {
          "limit": {"type": "integer", "default": 10, "max": 100}
        },
        "response": {
          "200": {
            "tasks": [
              {
                "id": "string",
                "message": "string",
                "status": "string",
                "created_at": "ISO8601",
                "result": "string|null",
                "error": "string|null"
              }
            ]
          }
        }
      },
      "GET /api/conversations": {
        "description": "Conversation list",
        "auth_required": false,
        "response": {
          "200": {
            "conversations": [
              {"id": "string", "name": "string", "message_count": "integer"}
            ],
            "active": "string|null"
          }
        }
      },
      "POST /api/conversations": {
        "description": "Create a new conversation",
        "auth_required": false,
        "request_body": {
          "name": {"type": "string", "required": true, "max_length": 100}
        },
        "response": {
          "200": {
            "id": "string",
            "name": "string",
            "created_at": "ISO8601"
          }
        }
      },
      "POST /api/conversations/{id}/activate": {
        "description": "Activate a conversation",
        "auth_required": false,
        "response": {
          "200": {"status": "activated", "conversation_id": "string"}
        }
      },
      "DELETE /api/conversations/{id}": {
        "description": "Delete a conversation",
        "auth_required": true,
        "response": {
          "200": {"status": "deleted", "conversation_id": "string"}
        }
      },
      "POST /api/settings": {
        "description": "Update a setting",
        "auth_required": true,
        "request_body": {
          "key": {"type": "string", "required": true},
          "value": {"type": "string", "required": true}
        },
        "response": {
          "200": {"status": "saved", "key": "string"}
        }
      },
      "GET /api/status": {
        "description": "LLM connection status",
        "auth_required": false,
        "response": {
          "200": {
            "connected": "boolean",
            "provider": "string",
            "model": "string",
            "latency_ms": "integer"
          }
        }
      },
      "GET /api/history": {
        "description": "Active conversation history",
        "auth_required": false,
        "response": {
          "200": {
            "messages": [
              {
                "role": "enum[user, assistant, system]",
                "content": "string",
                "timestamp": "ISO8601",
                "file_data": {
                  "name": "string",
                  "type": "string",
                  "size": "integer",
                  "base64": "string"
                }
              }
            ]
          }
        }
      },
      "GET /api/global_stream": {
        "description": "Global event stream (SSE)",
        "auth_required": false,
        "content_type": "text/event-stream",
        "events": [
          {
            "event": "task_update",
            "data": {"task_id": "string", "status": "string", "progress": "integer"}
          },
          {
            "event": "play_sound",
            "data": {"message": "string"}
          }
        ]
      },
      "GET /api/project": {
        "description": "Current project information",
        "auth_required": false,
        "response": {
          "200": {
            "name": "string",
            "path": "string",
            "file_count": "integer"
          }
        }
      }
    }
  },
  "data_models": {
    "Task": {
      "id": {"type": "string", "format": "uuid-short", "example": "a1b2c3d4"},
      "message": {"type": "string", "description": "Original message text"},
      "status": {"type": "string", "enum": ["pending", "running", "complete", "error"]},
      "result": {"type": "string", "nullable": true},
      "error": {"type": "string", "nullable": true},
      "created_at": {"type": "string", "format": "ISO8601"},
      "updated_at": {"type": "string", "format": "ISO8601", "nullable": true},
      "conversation_id": {"type": "string", "nullable": true}
    },
    "Conversation": {
      "id": {"type": "string", "format": "uuid"},
      "name": {"type": "string"},
      "messages": {
        "type": "array",
        "items": {
          "role": {"type": "string", "enum": ["user", "assistant", "system"]},
          "content": {"type": "string"},
          "timestamp": {"type": "string", "format": "ISO8601"},
          "file_data": {
            "type": "object",
            "nullable": true,
            "properties": {
              "name": {"type": "string"},
              "type": {"type": "string"},
              "size": {"type": "integer"},
              "base64": {"type": "string"}
            }
          }
        }
      },
      "created_at": {"type": "string", "format": "ISO8601"}
    },
    "Settings": {
      "lang": {"type": "string", "enum": ["en", "ar"], "default": "ar"},
      "theme": {"type": "string", "enum": ["dark", "light"], "default": "dark"},
      "provider": {"type": "string", "default": "openrouter"},
      "model": {"type": "string", "default": ""},
      "openrouter_key": {"type": "string", "sensitive": true},
      "groq_key": {"type": "string", "sensitive": true},
      "gemini_key": {"type": "string", "sensitive": true},
      "system_instructions": {"type": "string", "default": ""},
      "project_dir": {"type": "string", "default": "emo-ai"},
      "auth_enabled": {"type": "boolean", "default": false},
      "auth_username": {"type": "string"},
      "auth_password_hash": {"type": "string"},
      "telegram_token": {"type": "string", "sensitive": true},
      "telegram_enabled": {"type": "boolean", "default": true},
      "permissions": {"type": "object", "default": {}},
      "custom_providers": {"type": "object", "default": {}}
    },
    "Agent": {
      "name": {"type": "string"},
      "status": {"type": "string", "enum": ["idle", "busy", "error"]},
      "current_task": {"type": "string", "nullable": true},
      "brain": {"type": "Brain", "description": "LLM connection instance"}
    }
  },
