# EMO AI Orchestrator — Environment Variables
# انسخ هذا الملف إلى .env واملأ القيم الخاصة بك
# ⚠️ لا ترفع ملف .env إلى Git أبداً

# === LLM Providers (API) ===
OPENROUTER_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=

# === LLM Provider (Local — Ollama) ===
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# === Active Provider ===
# الخيارات: openrouter | groq | gemini | ollama
LLM_PROVIDER=openrouter
LLM_MODEL=

# === Authentication ===
EMO_AUTH_ENABLED=false
EMO_AUTH_USERNAME=
EMO_AUTH_PASSWORD=
EMO_JWT_SECRET=change-me-to-a-random-secure-string

# === Telegram ===
TELEGRAM_TOKEN=
TELEGRAM_ENABLED=false

# === Cloud Services ===
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
FIREBASE_API_KEY=
FIREBASE_PROJECT_ID=
GITHUB_TOKEN=

# === Server ===
PORT=8080
HOST=0.0.0.0
DEBUG=true

# === Project ===
EMO_AI_WORKSPACE_ROOT=.
EMO_PROJECT_DIR=.
